# Supabase 服务端数据源。
# 当前项目的浏览器端不直接保存数据，前端统一通过 /api/deliveries 访问服务端。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 可选：显式强制服务端使用指定数据源。Docker 默认使用 sqlite。
# DATA_STORE=supabase
# DATA_STORE=sqlite
DATA_STORE=

# 可选：SQLite 数据库文件路径。Docker 镜像默认固定为 /app/data/deliveries.sqlite；
# 本地不配置时默认使用 data/deliveries.sqlite。
# SQLITE_DB_PATH=data/deliveries.sqlite

# 保护管理写接口。部署到 Vercel/生产环境时必须配置；
# 进入 /admin 页面时输入这串密码，服务端验证通过后写入 HttpOnly Cookie。
ADMIN_API_TOKEN=
