# 默认 browser：浏览器 localStorage，适合本地静态 HTML。
# api：前端通过 /api/deliveries 读写，适合 Vercel + Supabase。
NEXT_PUBLIC_DATA_MODE=browser

# 服务端存储模式：local | supabase。留空时本地开发用 data/deliveries.local.json，Vercel 可继续用 Blob。
DATA_STORE=

# Supabase 只在服务端读取，不要加 NEXT_PUBLIC_。
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 保护管理写接口。生产环境建议配置。
ADMIN_API_TOKEN=

# 可选：仅在可信预览环境中把管理 token 注入浏览器 API provider。
# 更安全的方式是在浏览器 sessionStorage 设置 edu-system.admin-token。
NEXT_PUBLIC_ADMIN_API_TOKEN=
