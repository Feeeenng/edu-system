# Supabase 服务端数据源。
# 当前项目的浏览器端不直接保存数据，前端统一通过 /api/deliveries 访问服务端。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 可选：显式强制服务端使用 Supabase。默认检测到 NEXT_PUBLIC_SUPABASE_* 后会自动启用。
# DATA_STORE=supabase
DATA_STORE=

# 保护管理写接口。部署到 Vercel/生产环境时必须配置；
# 进入 /admin 页面时输入这串密码，服务端验证通过后写入 HttpOnly Cookie。
ADMIN_API_TOKEN=
