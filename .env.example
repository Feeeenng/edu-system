# Supabase 服务端数据源。
# 当前项目的浏览器端不直接保存数据，前端统一通过 /api/deliveries 访问服务端。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 可选：显式强制服务端使用 Supabase。默认检测到 NEXT_PUBLIC_SUPABASE_* 后会自动启用。
# DATA_STORE=supabase
DATA_STORE=

# 保护管理写接口。部署到 Vercel/生产环境时建议配置。
ADMIN_API_TOKEN=

# 可选：仅在可信预览环境中把管理 token 注入浏览器 API provider。
# 更安全的方式是在浏览器 sessionStorage 设置 edu-system.admin-token。
NEXT_PUBLIC_ADMIN_API_TOKEN=
